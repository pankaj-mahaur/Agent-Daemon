{
  "// GRAPHIFY PRETOOLUSE HOOK": "",
  "// Add this to .claude/settings.json under \"hooks\" to make Claude": "",
  "// check the knowledge graph before searching raw files.": "",
  "//": "",
  "// How it works:": "",
  "// 1. Before every Glob or Grep call, this hook checks if graphify-out/graph.json exists": "",
  "// 2. If it does, Claude gets a reminder to read GRAPH_REPORT.md first": "",
  "// 3. This means Claude understands your codebase architecture before diving into files": "",
  "//": "",
  "// Prerequisites: Run /graphify on your project at least once to build the graph": "",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}
